# App
APP_ENV=development
SECRET_KEY=CHANGE_ME_BEFORE_PRODUCTION
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database
DATABASE_URL=postgresql+asyncpg://omuzubuzi:omuzubuzi_pass@db:5432/omuzubuzi
REDIS_URL=redis://redis:6379/0

# Africa's Talking (SMS/OTP)
AT_API_KEY=your_africas_talking_api_key
AT_USERNAME=your_at_username
AT_SENDER_ID=OMUZUBUZI

# MTN MoMo
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_COLLECTION_KEY=your_mtn_collection_key
MTN_MOMO_COLLECTION_SECRET=your_mtn_collection_secret
MTN_MOMO_SUBSCRIPTION_KEY=your_subscription_key

# Airtel Money
AIRTEL_BASE_URL=https://openapi.airtel.africa
AIRTEL_CLIENT_ID=your_airtel_client_id
AIRTEL_CLIENT_SECRET=your_airtel_client_secret

# AWS S3
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=af-south-1
S3_BUCKET_NAME=omuzubuzi-uploads

# Regulatory
NPS_ID_VERIFICATION_THRESHOLD=1000000
URA_TRANSACTION_RETENTION_YEARS=7
